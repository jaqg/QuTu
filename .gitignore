# =============================================================================
# .gitignore for Quantum Tunnelling Project (Fortran/Python)
# =============================================================================

# -----------------------------------------------------------------------------
# Fortran compiled files
# -----------------------------------------------------------------------------
*.o
*.mod
*.a
*.so

# Fortran executable (without extension)
src/doble_pozo_NH3

# Backup files
*.bak

# -----------------------------------------------------------------------------
# Python artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
.eggs/
*.egg

# Virtual environments
venv/
env/
.venv/

# -----------------------------------------------------------------------------
# Output data files (regenerable from code)
# -----------------------------------------------------------------------------
src/data/out-*.dat

# -----------------------------------------------------------------------------
# Generated graphics (regenerable from scripts)
# -----------------------------------------------------------------------------
src/grafica/*.pdf
src/grafica/*.svg

# Animation outputs
src/animacion/videos/*.mp4
src/animacion/videos/*.avi
src/animacion/graficas/*.png

# -----------------------------------------------------------------------------
# Editor and IDE files
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.log
