# =============================================================================
# .gitignore for QuTu - Quantum Tunneling Simulation
# =============================================================================

# Build artifacts
build/
*.o
*.mod
*.exe
*.out
*.a
*.so
QuTu
qutu
doble_pozo_NH3

# Data and results (user-generated)
data/
results/
*/data/
*/results/
**/data/
**/results/

# Visualization output
*.pdf
*.png
*.eps
*.svg

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
.eggs/
*.egg
env/
venv/
ENV/
.venv

# Editor files
*~
*.swp
*.swo
.vscode/
.idea/
*.sublime-*

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# LaTeX auxiliary files
*.aux
*.log
*.toc
*.bbl
*.blg
*.synctex.gz
*.fdb_latexmk
*.fls

# Temporary files
*.orig
*.rej
*.bak
*.tmp
*.temp
